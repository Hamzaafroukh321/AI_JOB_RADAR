# Application (development-safe placeholders; change local credentials)
APP_ENV=development
APP_MODE=SINGLE_USER
BACKEND_PORT=8080
APP_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:4200
FRONTEND_API_BASE_URL=/api
APP_TIMEZONE=Africa/Casablanca
APP_DEFAULT_LOCALE=en
APP_REGISTRATION_ENABLED=false
ALLOWED_ORIGINS=http://localhost:4200
JOB_SOURCES_ENABLED=true
SESSION_COOKIE_SECURE=false
OPENAPI_ENABLED=true
MAX_UPLOAD_SIZE=10MB

# Development seed (explicitly opt in; never reuse in production)
DEV_SEED_ENABLED=true
DEV_SEED_EMAIL=developer@example.test
DEV_SEED_PASSWORD=change-this-local-password
DEV_SEED_DISPLAY_NAME="Hamza Afroukh"
DEV_SEED_PROFILE_ENABLED=true

# PostgreSQL
DATABASE_NAME=aijobradar
DATABASE_URL=jdbc:postgresql://localhost:5432/aijobradar
DATABASE_USERNAME=aijobradar
DATABASE_PASSWORD=change-this-local-database-password
DATABASE_POOL_MAX_SIZE=10

# Object storage / MinIO
STORAGE_ENABLED=true
STORAGE_PROVIDER=MINIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aijobradar
S3_ACCESS_KEY=aijobradar-local
S3_SECRET_KEY=change-this-local-storage-password
S3_PATH_STYLE=true
SIGNED_URL_TTL_SECONDS=300

# Authentication/session and future encryption (runtime secrets in production)
SESSION_SECRET=
ENCRYPTION_MASTER_KEY=
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
LOGIN_MAX_ATTEMPTS=5

# Mail (Mailpit is development-only)
EMAIL_PROVIDER=CONSOLE
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.test

# Groq is optional in Phase 3. Keep this server-side and empty unless explicitly enabling AI.
AI_ENABLED=false
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile
GROQ_MODEL_RESUME=llama-3.3-70b-versatile
GROQ_MODEL_TRANSLATION=llama-3.1-8b-instant
GROQ_REQUEST_TIMEOUT_SECONDS=60
GROQ_MAX_RETRIES=2
GROQ_DAILY_TOKEN_BUDGET=0

# Optional source credentials. Public approved sources do not require these values.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=
SMARTRECRUITERS_API_KEY=

# Observability
LOG_LEVEL=INFO
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
